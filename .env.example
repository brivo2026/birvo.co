# ==========================================================================
# BIRVO — Variables de entorno (ejemplo)
# Copia este archivo a .env y ajusta los valores para tu entorno local.
# NUNCA subas el archivo .env real a un repositorio.
# ==========================================================================

# --- General ---------------------------------------------------------------
NODE_ENV=development
APP_NAME=BIRVO
LOG_LEVEL=debug

# --- API (apps/api) ---------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Sesiones / JWT (usado para firmar la cookie de sesión httpOnly)
SESSION_COOKIE_NAME=birvo_session
SESSION_JWT_SECRET=change_this_dev_only_secret_please_rotate_in_prod_min_32_chars
SESSION_TTL_HOURS=12
SESSION_REFRESH_TTL_DAYS=14

# Cifrado de credenciales externas (AES-256-GCM, 32 bytes en base64)
CREDENTIALS_ENCRYPTION_KEY=ZGV2X29ubHlfMzJfYnl0ZV9rZXlfY2hhbmdlX21lXzEyMzQ1Ng==

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# --- Base de datos -----------------------------------------------------------
DATABASE_URL=postgresql://birvo:birvo_dev_password@localhost:5432/birvo?schema=public

# --- Redis / Colas -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Almacenamiento (S3 compatible / MinIO) ----------------------------------
# STORAGE_DRIVER: "s3" (MinIO/S3 real) o "local" (disco local, útil sin Docker)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=birvo_minio
S3_SECRET_ACCESS_KEY=birvo_minio_password
S3_BUCKET=birvo-attachments
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/birvo-attachments

# --- Correo de desarrollo (Mailpit) ------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@birvo.local

# --- Canales / Meta (opcional, adaptador queda desactivado sin credenciales) -
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
INSTAGRAM_PAGE_TOKEN=
MESSENGER_PAGE_TOKEN=

# Canal sandbox (siempre activo en development)
SANDBOX_CHANNEL_ENABLED=true

# --- IA -----------------------------------------------------------------------
# AI_PROVIDER: "mock" (por defecto, no requiere credenciales) u "openai"
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Transcripción --------------------------------------------------------------
# TRANSCRIPTION_PROVIDER: "mock" (por defecto) u otro proveedor real futuro
TRANSCRIPTION_PROVIDER=mock

# --- Worker (apps/worker) ----------------------------------------------------
WORKER_CONCURRENCY=5
INACTIVITY_TIMER_DEFAULT_MINUTES=5

# --- Observabilidad -----------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=birvo-api

# --- Web (apps/web) ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=BIRVO
