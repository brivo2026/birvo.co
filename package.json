{
  "name": "birvo",
  "private": true,
  "version": "0.1.0",
  "description": "BIRVO — Tus conversaciones. Un solo lugar.",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "dotenv -e .env -- turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @birvo/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "db:generate": "dotenv -e .env -- pnpm --filter @birvo/database generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @birvo/database migrate:dev",
    "db:migrate:deploy": "dotenv -e .env -- pnpm --filter @birvo/database migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @birvo/database seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @birvo/database studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
