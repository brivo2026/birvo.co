{
  "name": "@birvo/worker",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@birvo/ai-sdk": "workspace:*",
    "@birvo/channel-sdk": "workspace:*",
    "@birvo/config": "workspace:*",
    "@birvo/contracts": "workspace:*",
    "@birvo/database": "workspace:*",
    "@birvo/logger": "workspace:*",
    "@aws-sdk/client-s3": "^3.723.0",
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@birvo/eslint-config": "workspace:*",
    "@birvo/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
